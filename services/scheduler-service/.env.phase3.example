# Phase 3: Advanced Features Configuration
# Copy this to .env and update values for your environment

# ============================================
# Job Queue Configuration
# ============================================
JOB_QUEUE_CONCURRENCY=4           # Number of parallel job processors
JOB_QUEUE_MAX_RETRIES=5           # Max retry attempts for failed jobs
JOB_QUEUE_RETRY_DELAY=2000        # Initial retry delay in ms (exponential backoff)

# ============================================
# Webhook Configuration
# ============================================
WEBHOOK_TIMEOUT=10000             # Webhook delivery timeout in ms
WEBHOOK_RETRY_POLICY=exponential  # exponential or fixed
WEBHOOK_MAX_RETRIES=5             # Max webhook delivery attempts
WEBHOOK_SECRET_KEY=your-secret-key-here  # HMAC secret for signing webhooks

# ============================================
# Circuit Breaker Configuration
# ============================================
CIRCUIT_BREAKER_THRESHOLD=50      # Failure percentage threshold (%)
CIRCUIT_BREAKER_RESET=30000       # Reset timeout in ms (30 seconds)

# ============================================
# Email Service (for job queue)
# ============================================
# Option 1: SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key

# Option 2: SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Option 3: AWS SES
AWS_SES_REGION=us-east-1

# ============================================
# SMS Service (for job queue)
# ============================================
# Option 1: Twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Option 2: AWS SNS
AWS_SNS_REGION=us-east-1

# ============================================
# Push Notification Service
# ============================================
# Option 1: Firebase
FIREBASE_CREDENTIALS_JSON=/path/to/firebase-credentials.json

# Option 2: OneSignal
ONESIGNAL_API_KEY=your-onesignal-api-key
ONESIGNAL_APP_ID=your-app-id

# ============================================
# Secrets Management (Phase 3)
# ============================================
SECRETS_SOURCE=env                # env, aws, or vault

# AWS Secrets Manager
AWS_REGION=us-east-1

# HashiCorp Vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=s.xxxxxxxxxxxxx

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=          # Leave empty if no password
REDIS_DB=0

# ============================================
# Database Configuration
# ============================================
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/database

# ============================================
# Monitoring & Observability
# ============================================
LOG_LEVEL=info           # debug, info, warn, error
SENTRY_DSN=              # Optional: Sentry error tracking
PROMETHEUS_PORT=9090     # Metrics port

# ============================================
# Feature Flags (Phase 3)
# ============================================
ENABLE_JOB_QUEUES=true
ENABLE_WEBHOOKS=true
ENABLE_CIRCUIT_BREAKERS=true
ENABLE_SECRETS_ROTATION=false  # Phase 4+
