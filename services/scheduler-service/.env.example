# rez-scheduler-service environment variables

# Server
SERVICE_NAME=rez-scheduler-service
PORT=4009
NODE_ENV=development

# MongoDB
# Generate credentials: openssl rand -base64 24
MONGO_INITDB_ROOT_USERNAME=rez_admin
MONGO_INITDB_ROOT_PASSWORD=change-me-generate-with-openssl-rand-base64-24
MONGODB_URI=mongodb://rez_admin:password@localhost:27017/rez-scheduler?authSource=admin

# Redis (for BullMQ)
# Generate password: openssl rand -hex 32
REDIS_PASSWORD=change-me-generate-with-openssl-rand-hex-32
# For authenticated Redis: redis://:password@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2

# Internal service URLs
PAYMENT_SERVICE_URL=http://localhost:4002
ORDER_SERVICE_URL=http://localhost:4001
FINANCE_SERVICE_URL=http://localhost:4010
NOTIFICATION_SERVICE_URL=http://localhost:4012
AUTH_SERVICE_URL=http://localhost:4000
CATALOG_SERVICE_URL=http://localhost:4005
MERCHANT_SERVICE_URL=http://localhost:4004

# Internal service token for service-to-service calls
INTERNAL_SERVICE_TOKEN=your-internal-service-token

# BullMQ Worker concurrency (default: 5)
# Increase for higher throughput on non-financial jobs
WORKER_CONCURRENCY=5

# Event Bus (Redis Streams)
EVENT_BUS_ENABLED=true
EVENT_CONSUMER_GROUP=rez-consumer
EVENT_STREAM_NAME=rez:events

# Sentry (optional)
SENTRY_DSN=

# JWT secret (for admin API auth)
JWT_SECRET=your-jwt-secret
